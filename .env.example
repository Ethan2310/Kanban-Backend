# Copy this file to .env.local and fill in your values
# .env.local is gitignored — never commit real secrets

# MySQL connection string
# __ maps to nested config keys (ConnectionStrings:DefaultConnection in .NET)
ConnectionStrings__DefaultConnection=Server=localhost;Port=3306;Database=thinkninja_kanban;User=kanban_user;Password=

# JWT — Secret must be at least 32 characters for HS256
Jwt__Secret=
Jwt__Issuer=ThinkNinjaKanban
Jwt__Audience=ThinkNinjaKanban
Jwt__ExpiryMinutes=60
